{
  "name": "@turnkey/frames-shared",
  "version": "1.0.0",
  "description": "Shared utilities for Turnkey frames",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "lint": "eslint '**/*.{js,ts}'",
    "lint:write": "eslint '**/*.{js,ts}' --fix",
    "prettier:check": "prettier --check \"**/*.{css,html,js,json,md,ts,tsx,yaml,yml}\" --ignore-path ../.prettierignore",
    "prettier:write": "prettier --write \"**/*.{css,html,js,json,md,ts,tsx,yaml,yml}\" --ignore-path ../.prettierignore"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "30.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "^2.8.4",
    "regenerator-runtime": "^0.14.1",
    "rollup": "4.59.0",
    "ts-jest": "29.4.11"
  },
  "dependencies": {
    "@hpke/core": "1.7.5",
    "bech32": "^2.0.0"
  }
}
