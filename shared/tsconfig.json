{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.cache/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.js", "*.ts"],
  "exclude": ["dist", "node_modules", ".rollup.cache"]
}
